<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Express Server — Home</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="home.css" />
</head>
<body>

  <!-- Background grid -->
  <div class="grid-bg"></div>
  <div class="noise-overlay"></div>

  <!-- NAV -->
  <nav class="navbar">
    <div class="nav-brand">
      <span class="dot"></span>
      <span class="brand-text">express<span class="accent">.</span>dev</span>
    </div>
    <div class="nav-actions">
      <a href="/login" class="nav-btn nav-btn--ghost" id="loginBtn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        Login
      </a>
      <a href="/signup" class="nav-btn nav-btn--filled" id="signupBtn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="8.5" cy="7" r="4"/>
          <line x1="20" y1="8" x2="20" y2="14"/>
          <line x1="23" y1="11" x2="17" y2="11"/>
        </svg>
        Sign Up
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <main class="hero">

    <div class="status-badge">
      <span class="pulse-dot"></span>
      Server running on port <span class="mono-highlight">8000</span>
    </div>

    <h1 class="hero-title">
      <span class="line line-1">Backend</span>
      <span class="line line-2">Dev <em>Zone</em></span>
    </h1>

    <p class="hero-sub">
      Production-grade Express.js server.<br />
      JWT authentication · CRUD operations · Zod validation.
    </p>

    <div class="code-block">
      <div class="code-header">
        <span class="code-dot red"></span>
        <span class="code-dot yellow"></span>
        <span class="code-dot green"></span>
        <span class="code-label">server.js</span>
      </div>
      <pre class="code-body"><span class="kw">const</span> express <span class="op">=</span> <span class="fn">require</span>(<span class="str">'express'</span>);
<span class="kw">const</span> app <span class="op">=</span> <span class="fn">express</span>();

app.<span class="fn">get</span>(<span class="str">'/'</span>, (req, res) <span class="op">=&gt;</span> {
  res.<span class="fn">send</span>(<span class="str">'Hello, World!'</span>);
});

app.<span class="fn">listen</span>(<span class="num">3000</span>);</pre>
    </div>

    <!-- CTA Buttons -->
    <div class="cta-row">
      <a href="/signup" class="cta-btn cta-btn--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="8.5" cy="7" r="4"/>
          <line x1="20" y1="8" x2="20" y2="14"/>
          <line x1="23" y1="11" x2="17" y2="11"/>
        </svg>
        Create Account
      </a>
      <a href="/login" class="cta-btn cta-btn--outline">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        Sign In
      </a>
    </div>

    <div class="footer-row">
      <span class="footer-item">Node.js</span>
      <span class="sep">·</span>
      <span class="footer-item">Express</span>
      <span class="sep">·</span>
      <span class="footer-item">JWT + Bcrypt</span>
      <span class="sep">·</span>
      <span class="footer-item">MongoDB</span>
    </div>

  </main>

  <script src="script.js"></script>
</body>
</html>
</pre>